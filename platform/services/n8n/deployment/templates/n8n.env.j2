{# n8n compose env — rendered by deploy-n8n.yml from OpenBao via manage-secrets.
   Read by BOTH n8n-postgres (init creds) and n8n / n8n-worker (DB connection +
   encryption key). .env is gitignored + overwritten on every deploy.

   N8N_ENCRYPTION_KEY is STATEFUL: re-keying makes every stored workflow
   credential permanently undecryptable. manage-secrets generates it once into
   OpenBao and reuses it thereafter; for the EXISTING prod instance it must be
   pre-seeded from the live value FIRST (seed-n8n-secrets.yml / Task 0). #}
# --- postgres init (n8n-postgres) ---
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD={{ secrets.db_admin_password }}
POSTGRES_DB=n8n
POSTGRES_NON_ROOT_USER=n8n_user
POSTGRES_NON_ROOT_PASSWORD={{ secrets.db_user_password }}

# --- n8n app DB connection (connects as the non-root n8n_user) ---
DB_POSTGRESDB_PASSWORD={{ secrets.db_user_password }}

# --- n8n encryption key (STATEFUL — never regenerate against a live instance) ---
N8N_ENCRYPTION_KEY={{ secrets.encryption_key }}
