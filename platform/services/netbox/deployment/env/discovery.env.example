# Diode Discovery Server Environment
# Used by: diode-ingester, diode-reconciler, diode-auth, hydra, diode-redis

# ─── Diode Redis (separate from NetBox Redis) ─────────────────────
# The ingester and reconciler expect REDIS_PASSWORD in their container env.
# This is the Diode Redis password (NOT the NetBox Redis password).
REDIS_PASSWORD=

# ─── NetBox connection ─────────────────────────────────────────────
NETBOX_DIODE_PLUGIN_API_BASE_URL=http://netbox:8080/api/plugins/diode
NETBOX_DIODE_PLUGIN_SKIP_TLS_VERIFY=true

# ─── Logging ───────────────────────────────────────────────────────
LOGGING_LEVEL=INFO
SENTRY_DSN=

# ─── Reconciler tuning ────────────────────────────────────────────
MIGRATION_ENABLED=true
RECONCILER_RATE_LIMITER_RPS=20
RECONCILER_RATE_LIMITER_BURST=1
DIODE_TO_NETBOX_RATE_LIMITER_RPS=20
DIODE_TO_NETBOX_RATE_LIMITER_BURST=1

# ─── PostgreSQL (shared with NetBox — same postgres container) ─────
# These must match the Diode values in env/postgres.env
DIODE_POSTGRES_HOST=postgres
DIODE_POSTGRES_PORT=5432
DIODE_POSTGRES_DB_NAME=diode
DIODE_POSTGRES_USER=diode
DIODE_POSTGRES_PASSWORD=

# ─── Telemetry ─────────────────────────────────────────────────────
TELEMETRY_ENVIRONMENT=dev
TELEMETRY_METRICS_EXPORTER=prometheus
TELEMETRY_TRACES_EXPORTER=none

# ─── Hydra (OAuth2 provider) ──────────────────────────────────────
# Note: DSN and system secret are NOT set here.
#   DSN            → set via compose variable substitution from root .env (written by generate-secrets.sh)
#   secrets.system → written directly into discovery/hydra.yaml by generate-secrets.sh
HYDRA_POSTGRES_DB_NAME=hydra
HYDRA_POSTGRES_USER=hydra
HYDRA_POSTGRES_PASSWORD=

HYDRA_STRATEGIES_ACCESS_TOKEN=jwt
HYDRA_STRATEGIES_REFRESH_TOKEN=jwt
HYDRA_STRATEGIES_JWT_SCOPE_CLAIM=both
HYDRA_TTL_ACCESS_TOKEN=1h
HYDRA_OIDC_SUBJECT_IDENTIFIERS_SUPPORTED_TYPES=public
HYDRA_URLS_SELF_ISSUER=http://hydra:4444

# ─── Auth ──────────────────────────────────────────────────────────
AUTH_HTTP_PORT=8080
OAUTH2_PUBLIC_SERVER_URL=http://hydra:4444
OAUTH2_ADMIN_SERVER_URL=http://hydra:4445
DIODE_AUTH_TOKEN_URL=http://diode-auth:8080/token

# ─── Diode-to-NetBox OAuth2 client ────────────────────────────────
# Generated by generate-secrets.sh. Registered in Hydra by deploy.sh via authmanager.
DIODE_TO_NETBOX_CLIENT_ID=diode-to-netbox
DIODE_TO_NETBOX_CLIENT_SECRET=

# ─── NetBox-to-Diode OAuth2 client ──────────────────────────────────
# Used by the NetBox Diode plugin for outbound communication to Diode.
# Generated by generate-secrets.sh. Registered in Hydra by deploy.sh via authmanager.
NETBOX_TO_DIODE_CLIENT_ID=netbox-to-diode
NETBOX_TO_DIODE_CLIENT_SECRET=

# ─── Diode-ingest OAuth2 client ────────────────────────────────────
# Used by the Orb Agent. Generated by generate-secrets.sh.
DIODE_INGEST_CLIENT_ID=diode-ingest
DIODE_INGEST_CLIENT_SECRET=
