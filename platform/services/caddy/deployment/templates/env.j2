{# Compose interpolation vars for Caddy — NON-secret (rendered by deploy-caddy.yml).
   compose reads .env automatically from the deployment dir. Prod defaults match
   the long-standing compose values, so a prod render is byte-identical to today.
   (The Cloudflare API key for prod DNS-01 is a separate secret, not wired here
   yet — local uses `local_certs` and needs none.) #}
CADDY_IMAGE={{ caddy_image | default('iarekylew00t/caddy-cloudflare:latest') }}
CADDYFILE={{ caddy_file | default('./Caddyfile') }}
CADDY_HTTP_BIND={{ caddy_http_bind | default('0.0.0.0') }}
CADDY_HTTP_PORT={{ caddy_http_port | default('80') }}
CADDY_HTTPS_BIND={{ caddy_https_bind | default('0.0.0.0') }}
CADDY_HTTPS_PORT={{ caddy_https_port | default('443') }}
