{# Local-dev Caddyfile, rendered by deploy-caddy.yml from inventory vars.
   TLS source:
     - caddy_tls_cert set -> serve the step-ca-minted wildcard leaf (a STABLE,
       shared root trusted once via `make local-tls-trust`). The cert is minted
       into ./certs by tasks/mint-internal-cert.yml and mounted at the container
       path in caddy_tls_cert/caddy_tls_key.
     - caddy_tls_cert unset -> fall back to Caddy's own internal CA (local_certs;
       ephemeral per-instance root).
   Each caddy_routes entry is {host, upstream}; the upstream is usually a
   local-dev container name (Caddy joins that network via compose.local.yml),
   but it can be any address — e.g. host.containers.internal:PORT for a service
   that runs in its own compose project (NetBox) rather than on local-dev.
   Do NOT edit by hand — re-run the playbook. #}
{% set _cert = caddy_tls_cert | default('') %}
{
{% if not _cert %}	local_certs
{% endif %}	metrics
}

{% for r in caddy_routes | default([]) %}
{{ r.host }} {
{% if _cert %}	tls {{ _cert }} {{ caddy_tls_key }}
{% endif %}	reverse_proxy {{ r.upstream }}
}

{% endfor %}
# Per-service fragments distributed by tasks/distribute-caddy-site.yml (none yet
# locally — the glob tolerates zero matches).
import sites/*.caddy
