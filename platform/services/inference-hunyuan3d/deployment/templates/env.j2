{# inference-hunyuan3d — env file template
   Rendered by Ansible's tasks/manage-secrets.yml on each deploy.

   secrets.<name>  — credentials from OpenBao (keys = deploy playbook's
                     `_secret_definitions`): minio_root_user, minio_root_password.
                     Optional minio_access_key / minio_secret_key may also be set
                     for a scoped key; they default to the root creds below.
   hunyuan_<name>  — NON-secret config from inventory/group_vars (defaults below).
#}
# inference-hunyuan3d — production .env
# Generated by Ansible deploy-inference-hunyuan3d.yml on {{ ansible_date_time.iso8601 | default('<deploy-time>') }}
# Do NOT edit by hand.

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH={{ hunyuan_model_path | default('/weights/hunyuan3d-2-mini') }}
DEVICE={{ hunyuan_device | default('cuda') }}
HUNYUAN3D_WEIGHTS_DIR={{ hunyuan_weights_dir | default('/srv/hunyuan3d/weights') }}

# ── Service ──────────────────────────────────────────────────────────────────
SERVICE_PORT=8001
SERVICE_LOG_LEVEL={{ hunyuan_log_level | default('info') }}

# ── MinIO (independent — per-service decision) ───────────────────────────────
MINIO_ROOT_USER={{ secrets.minio_root_user }}
MINIO_ROOT_PASSWORD={{ secrets.minio_root_password }}
MINIO_ENDPOINT={{ hunyuan_minio_endpoint | default('minio:9000') }}
MINIO_ACCESS_KEY={{ secrets.minio_access_key | default(secrets.minio_root_user) }}
MINIO_SECRET_KEY={{ secrets.minio_secret_key | default(secrets.minio_root_password) }}
MINIO_BUCKET={{ hunyuan_minio_bucket | default('generated-3d') }}
MINIO_USE_SSL=false
# Public, central-Caddy-routed prefix the wrapper prepends to stored asset keys.
GENERATED_URL_PREFIX={{ hunyuan_generated_url_prefix | default('/generated/3d') }}

# ── Generation defaults ──────────────────────────────────────────────────────
MAX_PROMPT_LENGTH={{ hunyuan_max_prompt_length | default('1000') }}
DEFAULT_RESOLUTION={{ hunyuan_default_resolution | default('256') }}
EMIT_GLB={{ hunyuan_emit_glb | default('true') }}
EMIT_STL={{ hunyuan_emit_stl | default('true') }}
