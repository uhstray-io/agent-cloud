{# UhhCraft — env file template
   Rendered by Ansible's tasks/manage-secrets.yml on each deploy.
   Inputs: facts loaded from OpenBao via community.hashi_vault.
   Output: <SCRIPT_DIR>/.env (gitignored, read by compose env_file + the Go app).
#}
# UhhCraft — production .env
# Generated by Ansible deploy-uhhcraft.yml on {{ ansible_date_time.iso8601 | default('<deploy-time>') }}
# Do NOT edit by hand. Re-run the playbook to refresh.

# ── App ──────────────────────────────────────────────────────────────────────
# Variable names must match internal/config/config.go exactly — the app boots
# via requireEnv() and aborts if any required key is missing/misnamed.
APP_ENV={{ uhhcraft_env | default('production') }}
APP_PORT=3000
APP_BASE_URL={{ uhhcraft_base_url }}
SESSION_SECRET={{ uhhcraft_session_secret }}
GIT_SHA={{ uhhcraft_git_sha | default('unknown') }}
UHHCRAFT_IMAGE={{ uhhcraft_image | default('ghcr.io/uhstray-io/uhhcraft:latest') }}

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_DB={{ uhhcraft_postgres_db | default('uhhcraft') }}
POSTGRES_USER={{ uhhcraft_postgres_user | default('uhhcraft') }}
POSTGRES_PASSWORD={{ uhhcraft_postgres_password }}
{# Percent-encode credentials embedded in the connection URLs so a password
   containing URL-reserved chars (@ : / # ? %) doesn't corrupt parsing. The
   raw POSTGRES_PASSWORD above is consumed by the postgres container directly. #}
DATABASE_URL=postgres://{{ uhhcraft_postgres_user | default('uhhcraft') | urlencode }}:{{ uhhcraft_postgres_password | urlencode }}@postgres:5432/{{ uhhcraft_postgres_db | default('uhhcraft') }}?sslmode=disable

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD={{ uhhcraft_redis_password }}
REDIS_URL=redis://:{{ uhhcraft_redis_password | urlencode }}@redis:6379/0

# ── MinIO (UhhCraft-owned; catalog assets only) ──────────────────────────────
# ROOT_* configure the minio container; ACCESS/SECRET_KEY are what the Go app
# reads (config.go). They default to the root creds unless a scoped key is set.
MINIO_ROOT_USER={{ uhhcraft_minio_root_user }}
MINIO_ROOT_PASSWORD={{ uhhcraft_minio_root_password }}
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY={{ uhhcraft_minio_access_key | default(uhhcraft_minio_root_user) }}
MINIO_SECRET_KEY={{ uhhcraft_minio_secret_key | default(uhhcraft_minio_root_password) }}
MINIO_BUCKET={{ uhhcraft_minio_bucket | default('uhhcraft') }}
MINIO_USE_SSL=false

# ── AI sidecars (separate platform services) ─────────────────────────────────
AI_IMAGE_SERVICE_URL={{ uhhcraft_ai_image_url }}
AI_3D_SERVICE_URL={{ uhhcraft_ai_3d_url }}

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY={{ uhhcraft_stripe_secret_key }}
STRIPE_PUBLISHABLE_KEY={{ uhhcraft_stripe_publishable_key }}
STRIPE_WEBHOOK_SECRET={{ uhhcraft_stripe_webhook_secret }}
STRIPE_MODE={{ uhhcraft_stripe_mode | default('test') }}

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY={{ uhhcraft_resend_api_key }}
EMAIL_FROM={{ uhhcraft_email_from | default('orders@uhhcraft.uhstray.io') }}

# ── Discord notifications ────────────────────────────────────────────────────
# Two separate webhooks (orders vs ops) per config.go.
DISCORD_ORDERS_WEBHOOK_URL={{ uhhcraft_discord_orders_webhook_url }}
DISCORD_OPS_WEBHOOK_URL={{ uhhcraft_discord_ops_webhook_url }}

# ── USPS (shipping rates, v3 OAuth2) ─────────────────────────────────────────
# Names must match internal/config/config.go (USPS_CLIENT_ID / USPS_CLIENT_SECRET)
# and the OAuth2 client_credentials grant documented in config/usps.toml.
USPS_CLIENT_ID={{ uhhcraft_usps_client_id }}
USPS_CLIENT_SECRET={{ uhhcraft_usps_client_secret }}

# ── Fulfillment (Printify = sticker overflow, Hubs = 3D print overflow) ──────
# Names match config.go + config/printify.toml + config/fulfillment_3d.toml.
PRINTIFY_API_KEY={{ uhhcraft_printify_api_key | default('') }}
PRINTIFY_SHOP_ID={{ uhhcraft_printify_shop_id | default('') }}
HUBS_API_KEY={{ uhhcraft_hubs_api_key | default('') }}

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL={{ uhhcraft_log_level | default('info') }}
LOG_FORMAT={{ uhhcraft_log_format | default('json') }}
