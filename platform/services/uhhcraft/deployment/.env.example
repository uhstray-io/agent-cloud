# UhhCraft — example env for LOCAL DEVELOPMENT ONLY.
# Production .env is templated by Ansible from OpenBao; never edit on the server.
# Copy to .env and fill in for local dev:
#   cp .env.example .env
#   openssl rand -hex 32   # for SESSION_SECRET
#
# This file MUST NOT contain real production credentials.

APP_ENV=development
APP_PORT=3000
# Variable names below must match internal/config/config.go — the app boots via
# requireEnv() and panics on a missing/misnamed key. Keep this in lockstep with
# templates/env.j2.
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=please-generate-with-openssl-rand-hex-32
GIT_SHA=local-dev
UHHCRAFT_IMAGE=uhhcraft:dev

POSTGRES_DB=uhhcraft
POSTGRES_USER=uhhcraft
POSTGRES_PASSWORD=dev-only-not-for-prod
DATABASE_URL=postgres://uhhcraft:dev-only-not-for-prod@postgres:5432/uhhcraft?sslmode=disable  # trufflehog:ignore — local dev placeholder, not a real credential

REDIS_PASSWORD=dev-only-not-for-prod
REDIS_URL=redis://:dev-only-not-for-prod@redis:6379/0  # trufflehog:ignore — local dev placeholder, not a real credential

MINIO_ROOT_USER=dev-minio-user
MINIO_ROOT_PASSWORD=dev-only-not-for-prod
MINIO_ENDPOINT=minio:9000
# The Go app reads ACCESS/SECRET_KEY (default to the root creds locally).
MINIO_ACCESS_KEY=dev-minio-user
MINIO_SECRET_KEY=dev-only-not-for-prod
MINIO_BUCKET=uhhcraft
MINIO_USE_SSL=false

AI_IMAGE_SERVICE_URL=http://inference-comfyui:8189
AI_3D_SERVICE_URL=http://inference-hunyuan3d:8001

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_MODE=test

RESEND_API_KEY=re_replace_me
EMAIL_FROM=dev@localhost

DISCORD_ORDERS_WEBHOOK_URL=
DISCORD_OPS_WEBHOOK_URL=

USPS_CLIENT_ID=
USPS_CLIENT_SECRET=

PRINTIFY_API_KEY=
PRINTIFY_SHOP_ID=
HUBS_API_KEY=

LOG_LEVEL=debug
LOG_FORMAT=text
