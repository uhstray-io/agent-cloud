{# OpenHands central-Caddy fragment — rendered by deploy-openhands.yml on the
   OpenHands host, distributed to the central Caddy + reloaded by
   tasks/distribute-caddy-site.yml. canvas.uhstray.io, TLS via Caddy's internal
   CA (`tls internal` — trust Caddy's root once per client), gated by Authentik
   forward_auth against the embedded outpost. Mirrors the forward_auth block in
   services/caddy/deployment/templates/Caddyfile.local.j2. Do NOT edit by hand. #}
{{ openhands_public_host }} {
	tls internal

	route {
		# Only the outpost may set identity headers — strip any client-supplied
		# ones so a caller can't spoof X-authentik-username and bypass auth.
		request_header -X-authentik-username
		request_header -X-authentik-groups
		request_header -X-authentik-email
		request_header -X-authentik-name
		request_header -X-authentik-uid
		# Authentik embedded-outpost endpoints (login flow + callbacks).
		reverse_proxy /outpost.goauthentik.io/* {{ authentik_outpost_url }}
		# Authenticate every other request; on success the outpost returns the
		# X-authentik-* identity headers we copy upstream.
		forward_auth {{ authentik_outpost_url }} {
			uri /outpost.goauthentik.io/auth/caddy
			copy_headers X-authentik-username X-authentik-groups X-authentik-email X-authentik-name X-authentik-uid
			trusted_proxies private_ranges
		}
		# Authenticated traffic to OpenHands. flush_interval -1 keeps the live
		# agent event stream (SSE) unbuffered; Caddy negotiates WebSocket upgrades.
		reverse_proxy {{ openhands_caddy_upstream }} {
			flush_interval -1
		}
	}
}
