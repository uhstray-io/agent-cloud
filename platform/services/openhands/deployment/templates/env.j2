{# OpenHands compose env — rendered by deploy-openhands.yml from inventory vars.
   NON-secret only: image pins + the runtime "agent server" image OpenHands
   launches via the Docker socket + listen bind/port. LLM provider keys are NOT
   here — they're entered in the OpenHands UI and persisted in the state volume.
   .env is gitignored and overwritten on every deploy. Do NOT edit by hand. #}
OPENHANDS_IMAGE={{ openhands_image | default('docker.openhands.dev/openhands/openhands:1.8') }}

# Published listen socket (central Caddy reaches this over the LAN).
OPENHANDS_BIND={{ openhands_bind | default('0.0.0.0') }}
OPENHANDS_PORT={{ openhands_port | default('3000') }}

# Per-session runtime sandbox image OpenHands pulls + runs via the host Docker
# socket. Pinned for reproducibility; bump deliberately.
AGENT_SERVER_IMAGE_REPOSITORY={{ openhands_agent_server_repo | default('ghcr.io/openhands/agent-server') }}
AGENT_SERVER_IMAGE_TAG={{ openhands_agent_server_tag | default('1.26.0-python') }}

# Verbose event logging (matches the OpenHands docs' recommended run).
LOG_ALL_EVENTS={{ openhands_log_all_events | default('true') }}
