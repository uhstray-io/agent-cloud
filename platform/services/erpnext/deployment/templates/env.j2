{# ERPNext compose env — rendered by deploy-erpnext.yml from OpenBao via
   tasks/manage-secrets.yml on every deploy. NO literal secrets in this file —
   every credential comes from {{ secrets.* }} (locally these resolve to the
   LOCAL_FAKE_ values seeded at secret/services/erpnext; in prod, the real
   generated values). .env is gitignored + overwritten on every deploy and is
   NOT the source of truth.

   Read by: db (MYSQL_ROOT_PASSWORD), frontend (SITE_NAME), deploy.sh
   (ERPNEXT_VERSION substitution), and post-deploy.sh (SITE_NAME, DB_PASSWORD,
   ADMIN_PASSWORD, PUBLIC_URL).

   SLIM TIER: no MinIO / peer-backup keys — backup + cross-mirror are prod-only
   (plan §7.5 lists MINIO_*/PEER_* for the prod tier; omitted here). #}
# ERPNext — .env  (generated {{ ansible_date_time.iso8601 | default('<deploy-time>') }};
# do NOT edit by hand — re-run deploy-erpnext.yml to refresh)

# --- Images (env-parameterized; pinned defaults live in compose.yml) ---
ERPNEXT_IMAGE={{ erpnext_image | default('docker.io/frappe/erpnext') }}
ERPNEXT_VERSION={{ erpnext_version }}

# --- Site ---
SITE_NAME={{ erpnext_site_name }}
PUBLIC_URL={{ erpnext_public_url }}

# --- MariaDB / Admin (from OpenBao) ---
DB_PASSWORD={{ secrets.mariadb_root_password }}
ADMIN_PASSWORD={{ secrets.admin_password }}
