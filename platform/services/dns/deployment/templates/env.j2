{# Compose interpolation vars for the DNS stack — NON-secret (rendered by
   deploy-dns.yml). compose reads .env automatically from the deployment dir.
   The loopback port shift lives here, not in compose.local.yml, because
   compose merges `ports` lists by appending. #}
DNS_IMAGE={{ dns_image | default('docker.io/hickorydns/hickory-dns:0.26.0') }}
DNS_LISTEN={{ dns_listen | default('0.0.0.0') }}
DNS_PORT={{ dns_port | default('53') }}
DNS_ZONE={{ dns_zone }}
