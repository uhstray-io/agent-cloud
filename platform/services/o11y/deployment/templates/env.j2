{# o11y compose env — rendered by deploy-o11y.yml from OpenBao + inventory.
   Only the Grafana admin password is a secret (from OpenBao); the rest is
   non-secret config. .env is gitignored + overwritten per deploy. Configs
   (prometheus/loki/alloy/grafana provisioning) are committed, not here. #}
# --- images (pinned; multi-arch incl. arm64 for the podman-machine VM) ---
O11Y_GRAFANA_IMAGE={{ o11y_grafana_image | default('docker.io/grafana/grafana:11.4.0') }}
O11Y_PROM_IMAGE={{ o11y_prom_image | default('docker.io/prom/prometheus:v3.1.0') }}
O11Y_LOKI_IMAGE={{ o11y_loki_image | default('docker.io/grafana/loki:3.3.2') }}
O11Y_ALLOY_IMAGE={{ o11y_alloy_image | default('docker.io/grafana/alloy:v1.5.1') }}

# --- host debug ports (Caddy fronts Grafana; these are for loopback access) ---
O11Y_GRAFANA_BIND={{ o11y_grafana_bind | default('127.0.0.1') }}
O11Y_GRAFANA_PORT={{ o11y_grafana_port | default('3002') }}
O11Y_PROM_BIND={{ o11y_prom_bind | default('127.0.0.1') }}
O11Y_PROM_PORT={{ o11y_prom_port | default('9090') }}
O11Y_LOKI_BIND={{ o11y_loki_bind | default('127.0.0.1') }}
O11Y_LOKI_PORT={{ o11y_loki_port | default('3100') }}

# --- Grafana runtime (admin password from OpenBao; root URL behind Caddy) ---
GF_SECURITY_ADMIN_PASSWORD={{ secrets.grafana_admin_password }}
GF_SERVER_ROOT_URL=https://grafana.{{ o11y_zone | default('agent-cloud.test') }}:8443/

# --- Authentik OIDC (generic OAuth). Browser hits auth.<zone> via Caddy; the
# server-side token/userinfo calls use the internal container name (the
# *.<zone> host does NOT resolve inside containers). The break-glass local
# admin (GF_SECURITY_ADMIN_PASSWORD) stays usable. ---
GF_AUTH_GENERIC_OAUTH_ENABLED=true
GF_AUTH_GENERIC_OAUTH_NAME=Authentik
GF_AUTH_GENERIC_OAUTH_CLIENT_ID=grafana
GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET={{ secrets.grafana_oidc_client_secret }}
GF_AUTH_GENERIC_OAUTH_SCOPES=openid email profile
GF_AUTH_GENERIC_OAUTH_AUTH_URL=https://auth.{{ o11y_zone | default('agent-cloud.test') }}:8443/application/o/authorize/
GF_AUTH_GENERIC_OAUTH_TOKEN_URL=http://authentik-server:9000/application/o/token/
GF_AUTH_GENERIC_OAUTH_API_URL=http://authentik-server:9000/application/o/userinfo/
GF_AUTH_GENERIC_OAUTH_USE_PKCE=true
GF_AUTH_GENERIC_OAUTH_LOGIN_ATTRIBUTE_PATH=preferred_username
GF_AUTH_GENERIC_OAUTH_EMAIL_ATTRIBUTE_PATH=email
GF_AUTH_GENERIC_OAUTH_NAME_ATTRIBUTE_PATH=name
# Local-dev only: the OIDC server uses step-ca certs the Grafana container
# doesn't trust by default; skip verify locally (prod trusts the real CA).
GF_AUTH_GENERIC_OAUTH_TLS_SKIP_VERIFY_INSECURE=true
