{# step-ca compose env — rendered by deploy-step-ca.yml from OpenBao + inventory.
   STEPCA_INIT_PASSWORD (secret) protects the CA keys at rest; the keys live
   encrypted in the step-ca-data volume, NOT in OpenBao. Other values are
   non-secret config. Do NOT edit by hand. #}
STEPCA_IMAGE={{ stepca_image | default('docker.io/smallstep/step-ca:0.30.2') }}
STEPCA_BIND={{ stepca_bind | default('127.0.0.1') }}
STEPCA_PORT={{ stepca_port | default('9000') }}
STEPCA_NAME={{ stepca_name | default('agent-cloud Internal CA') }}
STEPCA_DNS_NAMES={{ stepca_dns_names | default('step-ca,localhost') }}
STEPCA_PROVISIONER={{ stepca_provisioner | default('admin') }}
STEPCA_INIT_ACME={{ stepca_init_acme | default('true') }}
STEPCA_INIT_PASSWORD={{ secrets.init_password }}
