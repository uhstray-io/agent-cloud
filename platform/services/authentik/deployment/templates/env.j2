{# authentik compose env — rendered by deploy-authentik.yml from OpenBao +
   inventory. Secrets (secret_key, bootstrap creds, db_password) come from
   OpenBao via manage-secrets; the rest is non-secret config. .env is gitignored
   and overwritten on every deploy. Do NOT edit by hand. #}
# --- compose substitution (postgres container + image/ports) ---
AUTHENTIK_IMAGE={{ authentik_image | default('ghcr.io/goauthentik/server:2024.12.3') }}
AUTHENTIK_BIND={{ authentik_bind | default('127.0.0.1') }}
AUTHENTIK_PORT={{ authentik_port | default('9300') }}
AUTHENTIK_POSTGRES_DB={{ authentik_postgres_db | default('authentik') }}
AUTHENTIK_POSTGRES_USER={{ authentik_postgres_user | default('authentik') }}
AUTHENTIK_POSTGRES_PASSWORD={{ secrets.db_password }}

# --- authentik runtime config (server + worker read these) ---
# Serve plain HTTP on :9000 — central Caddy terminates TLS in front.
AUTHENTIK_SECRET_KEY={{ secrets.secret_key }}
AUTHENTIK_LISTEN__HTTP=0.0.0.0:9000
AUTHENTIK_POSTGRESQL__HOST=postgresql
AUTHENTIK_POSTGRESQL__NAME={{ authentik_postgres_db | default('authentik') }}
AUTHENTIK_POSTGRESQL__USER={{ authentik_postgres_user | default('authentik') }}
AUTHENTIK_POSTGRESQL__PASSWORD={{ secrets.db_password }}
AUTHENTIK_REDIS__HOST=redis
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_DISABLE_UPDATE_CHECK=true

# --- first-boot bootstrap admin (akadmin) + API token ---
AUTHENTIK_BOOTSTRAP_PASSWORD={{ secrets.bootstrap_password }}
AUTHENTIK_BOOTSTRAP_TOKEN={{ secrets.bootstrap_token }}
AUTHENTIK_BOOTSTRAP_EMAIL={{ authentik_bootstrap_email | default('admin@agent-cloud.test') }}

# --- OIDC client secrets for blueprints (worker reads via !Env) ---
# NetBox uses forward_auth locally (proxy provider, no client secret).
GRAFANA_OIDC_CLIENT_SECRET={{ secrets.grafana_oidc_client_secret }}
ERPNEXT_OIDC_CLIENT_SECRET={{ secrets.erpnext_oidc_client_secret }}
SEMAPHORE_OIDC_CLIENT_SECRET={{ secrets.semaphore_oidc_client_secret }}
OPENBAO_OIDC_CLIENT_SECRET={{ secrets.openbao_oidc_client_secret }}

# --- day-to-day admin user (agent-cloud-admin.yaml blueprint reads via !Env) ---
AGENT_CLOUD_ADMIN_PASSWORD={{ secrets.agent_cloud_admin_password }}

# --- prod SSO wiring (browser-facing hosts; blueprints read via !Env) ---
# Embedded-outpost login-redirect target (zz-sso-bindings.yaml). Defaults to the
# local-dev host; prod inventory sets authentik_browser_host (e.g. auth.uhstray.io).
AUTHENTIK_BROWSER_HOST={{ authentik_browser_host | default('https://auth.agent-cloud.test:8443/') }}
# OpenHands forward_auth external host (openhands-forward-auth.yaml).
OPENHANDS_EXTERNAL_HOST={{ openhands_external_host | default('https://canvas.agent-cloud.test:8443/') }}

# --- 'stray' operator admin (stray-admin.yaml reads via !Env) ---
STRAY_ADMIN_PASSWORD={{ secrets.stray_admin_password }}
STRAY_ADMIN_EMAIL={{ stray_admin_email | default('stray@agent-cloud.test') }}

# --- platform service account API token (service-account.yaml reads via !Env) ---
SERVICE_ACCOUNT_TOKEN={{ secrets.service_account_token }}
