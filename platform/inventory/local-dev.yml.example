---
# Local-dev inventory TEMPLATE — committed, localhost-only by construction.
# `make local-init` copies this to platform/inventory/local-dev.yml (gitignored)
# and substitutes __REPO_DIR__ / __HOME_DIR__. No real IPs, domains, or
# credentials may ever appear here (plan/development/LOCAL-DEV-DEPLOYMENT.md).

all:
  vars:
    local_mode: true
    monorepo_repo: "https://github.com/uhstray-io/agent-cloud.git"
    openbao_addr: "http://127.0.0.1:8200"
    local_monorepo_dir: "__REPO_DIR__"
    local_home_dir: "__HOME_DIR__"
    ansible_python_interpreter: "{{ ansible_playbook_python }}"

  children:
    uhhcraft_svc:
      hosts:
        uhhcraft-local:
          ansible_host: 127.0.0.1
          ansible_connection: local
          service_name: uhhcraft
          service_url: "http://127.0.0.1:3001"
          health_path: "/healthz"
          monorepo_deploy_path: platform/services/uhhcraft/deployment
          container_engine: podman
          uhhcraft_port: 3001

    # Phase 2 coverage — uncomment as services gain local profiles
    # (port map registry of record: docs/LOCAL-DEV.md):
    #
    # nocodb_svc:
    #   hosts:
    #     nocodb-local:
    #       ansible_host: 127.0.0.1
    #       ansible_connection: local
    #       service_name: nocodb
    #       service_url: "http://127.0.0.1:8081"
    #       monorepo_deploy_path: platform/services/nocodb/deployment
    #       container_engine: podman
    #
    # netbox_svc:   # root-requiring: Docker Desktop profile, app tier only
    #   hosts:
    #     netbox-local:
    #       ansible_host: 127.0.0.1
    #       ansible_connection: local
    #       service_name: netbox
    #       service_url: "http://127.0.0.1:8000"
    #       monorepo_deploy_path: platform/services/netbox/deployment
    #       container_engine: docker
