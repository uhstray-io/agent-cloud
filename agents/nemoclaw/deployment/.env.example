# NemoClaw deployment configuration
# Copy to .env and fill in site-specific values

# Target VM (required for remote deploy)
NEMOCLAW_HOST=
NEMOCLAW_USER=
NEMOCLAW_SSH_KEY=~/.ssh/nemoclaw

# Deploy settings
NEMOCLAW_DEPLOY_DIR=nemoclaw-deploy
NEMOCLAW_REPO=https://github.com/uhstray-io/NemoClaw

# Secrets directory (copy from site-config/nemoclaw/secrets/)
NEMOCLAW_SECRETS_DIR=./secrets
