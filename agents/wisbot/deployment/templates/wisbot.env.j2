{# Rendered by tasks/manage-secrets.yml -> config/wisbot.env (mode 0600, gitignored). #}
{# Secret comes from OpenBao (secrets.*); site config from _-prefixed play vars set #}
{# in deploy-wisbot.yml from inventory host vars. No literal IDs/IPs/secrets here.   #}
DISCORD_TOKEN_WISBOT={{ secrets.discord_token }}
WISBOT_GUILD_ID={{ _wisbot_guild_id }}
OLLAMA_ENDPOINT={{ _wisbot_ollama_endpoint | default('http://localhost:11434') }}
OLLAMA_DEFAULT_MODEL={{ _wisbot_ollama_model | default('llama3') }}
WISBOT_HEALTH_HOST=+
WISBOT_HEALTH_PORT=8080
WISBOT_DB_PATH=/app/data/wisbot.db
WISBOT_RECORDINGS_DIR=/app/recordings
{% if _wisbot_test_voice_channel_id is defined %}
WISBOT_TEST_VOICE_CHANNEL_ID={{ _wisbot_test_voice_channel_id }}
{% endif %}
