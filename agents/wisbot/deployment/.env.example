# Example of the env file Ansible renders to config/wisbot.env at deploy time.
# Real values come from OpenBao (token) + site-config inventory (guild id, endpoint).
# This file is illustrative only — placeholders, never real values.

# Discord bot token (OpenBao: secret/services/wisbot -> discord_token)
DISCORD_TOKEN_WISBOT=

# Guild the bot serves (site-config inventory: wisbot_guild_id)
WISBOT_GUILD_ID=000000000000000000

# WisAI / Ollama endpoint (site-config inventory: wisbot_ollama_endpoint)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# Health endpoint — bind all interfaces in-container so the port mapping reaches it
WISBOT_HEALTH_HOST=+
WISBOT_HEALTH_PORT=8080

# Persistence (mounted volumes)
WISBOT_DB_PATH=/app/data/wisbot.db
WISBOT_RECORDINGS_DIR=/app/recordings
